#!/usr/bin/env python

"""
Sends a message to a telegram bot identified by a chat ID and bot token.  
"""

import argparse 
import json 
import os
import subprocess 
import sys

from typing import Optional 
from util.secrets import get as get_secrets


def get_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    
    if sys.stdin.isatty():
        parser.add_argument("message", type=str, help="The message to send") 

    parser.add_argument("--chat-id", required=False, default=None, 
        help="Telegram chat ID (may also be specified in secrets file)")
    parser.add_argument("--bot-token", required=False, default=None, 
        help="Telegram bot token (may also be specified in secrets file)")
    
    args = parser.parse_args() 
    if not sys.stdin.isatty():
        # It's not a TTY, so it's probably being piped from somewhere else. 
        args.message = sys.stdin.read().strip()
    
    return args 


def message(
    message: str,
    telegram_chat_id: Optional[str], 
    telegram_bot_token: Optional[str], 
) -> bool: 
    """
    Sends a message to the Telegram bot. Returns True if sending succeeded, or
    False if it failed. If the chat ID and bot token are not provided, then 
    obtain them from the secrets. 
    """
    
    if telegram_chat_id is None or telegram_bot_token is None: 
        secrets = get_secrets() 
        assert "TELEGRAM_CHAT_ID" in secrets
        assert "TELEGRAM_BOT_TOKEN" in secrets 
        telegram_chat_id = secrets["TELEGRAM_CHAT_ID"]
        telegram_bot_token = secrets["TELEGRAM_BOT_TOKEN"]

    proc = subprocess.run(
        [
            "curl", "-s", "X", "POST", 
            f"https://api.telegram.org/bot{telegram_bot_token}/sendMessage", 
            "-d", f"chat_id={telegram_chat_id}", 
            "-d", f"text={message}"
        ], 
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL
    )
    return proc.returncode == 0 


if __name__ == "__main__":
    args = get_args() 
    message(
        message=args.message, 
        telegram_chat_id=args.chat_id, 
        telegram_bot_token=args.bot_token
    )
